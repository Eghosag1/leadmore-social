# Copy this file to .env.local and fill in your Supabase project credentials.
# Find these in your Supabase project settings under API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: used to seed a first super_admin account (see scripts/seed.ts).
SEED_SUPER_ADMIN_EMAIL=admin@leadmore.be
SEED_SUPER_ADMIN_PASSWORD=change-me-please

# Meta (Facebook) OAuth — from your Meta Developer App's dashboard.
# META_REDIRECT_URI must exactly match a "Valid OAuth Redirect URI" registered there,
# e.g. http://localhost:3000/api/meta/callback for local dev.
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=http://localhost:3000/api/meta/callback

# 32-byte hex key used to encrypt stored Meta access tokens and to sign the OAuth
# state param. Generate your own with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=replace-with-openssl-rand--hex-32-output

# Optional: only needed for the "Business Portfolio" connect path (agency shares
# their Page with Leadmore's Business Manager instead of the personal OAuth flow).
# Generate in Meta Business Settings -> System Users -> (create/select one) ->
# Generate New Token -> pick this app + at least pages_show_list/pages_manage_posts.
META_SYSTEM_USER_TOKEN=your-system-user-token
